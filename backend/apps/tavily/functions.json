                    },
                    "auto_parameters": {
                        "type": "boolean",
                        "default": false,
                        "description": "When enabled, Tavily automatically configures search parameters based on query content and intent. Explicit values override automatic ones. Uses 2 API credits per request. Default is false."
                    },
                    "exact_match": {
                        "type": "boolean",
                        "default": false,
                        "description": "Ensure only results containing the exact quoted phrase(s) in the query are returned. Wrap target phrases in quotes within your query (e.g. '\"John Smith\" CEO'). Default is false."
                    },
                    "include_usage": {
                        "type": "boolean",
                        "default": false,
                        "description": "Whether to include credit usage information in the response. Default is false."
                    },
                    "safe_search": {
                        "type": "boolean",
                        "default": false,
                        "description": "Enterprise only. Whether to filter out adult or unsafe content from results. Not supported for 'fast' or 'ultra-fast' search depths. Default is false."
                    }
                },
                "required": [
                    "query",
                    "api_key"
                ],
                "visible": [
