  {
    "name": "TAVILY__EXTRACT",
    "description": "Tavily Extract API is used to scrape raw content from a provided list of URLs.",
    "tags": ["search", "scrape"],
    "visibility": "public",
    "active": true,
    "protocol": "rest",
    "protocol_data": {
      "method": "POST",
      "path": "/extract",
      "server_url": "https://api.tavily.com"
    },
    "parameters": {
      "type": "object",
      "properties": {
        "body": {
          "type": "object",
          "description": "body parameters",
          "properties": {
            "urls": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "The urls you want to extract with Tavily."
            },
            "api_key": {
              "type": "string",
              "default": "X-API-KEY",
              "description": "Your Tavily API Key."
            }
          },
          "required": ["urls", "api_key"],
          "visible": ["urls"],
          "additionalProperties": false
        }
      },
      "required": ["body"],
      "visible": ["body"],
      "additionalProperties": false
    },
    "response": {}
  }
