[
  {
    "name": "TAVILY__SEARCH",
    "description": "Tavily Search API is a search engine optimized for LLMs, aimed at efficient, quick and persistent search results.",
    "tags": [
        "search"
    ],
    "visibility": "public",
    "active": true,
    "protocol": "rest",
    "protocol_data": {
        "method": "POST",
        "path": "/search",
        "server_url": "https://api.tavily.com"
    },
    "parameters": {
        "type": "object",
        "properties": {
            "body": {
                "type": "object",
                "description": "body parameters",
                "properties": {
                    "query": {
                        "type": "string",
                        "description": "The search query you want to execute with Tavily."
                    },
                    "api_key": {
                        "type": "string",
                        "default": "X-API-KEY",
                        "description": "Your Tavily API Key."
                    },
                    "search_depth": {
                        "type": "string",
                        "default": "basic",
                        "description": "Controls the latency vs. relevance tradeoff. 'advanced': highest relevance, increased latency, 2 API credits. 'basic': balanced relevance and latency, 1 credit. 'fast': lower latency, good relevance, 1 credit. 'ultra-fast': minimum latency, 1 credit.",
                        "enum": [
                            "advanced",
                            "basic",
                            "fast",
                            "ultra-fast"
                        ]
                    },
                    "chunks_per_source": {
                        "type": "integer",
                        "default": 3,
                        "minimum": 1,
                        "maximum": 3,
                        "description": "Maximum number of relevant content chunks (up to 500 characters each) returned per source. Only available when search_depth is 'advanced'."
                    },
                    "topic": {
                        "type": "string",
                        "default": "general",
                        "description": "The category of the search. 'news' is useful for real-time updates on politics, sports, and major events. 'general' is for broader searches. 'finance' is for financial data.",
                        "enum": [
                            "general",
                            "news",
                            "finance"
                        ]
                    },
                    "time_range": {
                        "type": "string",
                        "default": null,
                        "description": "The time range back from the current date to filter results based on publish or last updated date. Options: 'day'/'d', 'week'/'w', 'month'/'m', 'year'/'y'.",
                        "enum": [
                            "day",
                            "week",
                            "month",
                            "year",
                            "d",
                            "w",
                            "m",
                            "y"
                        ]
                    },
                    "start_date": {
                        "type": "string",
                        "default": null,
                        "description": "Return results published or updated after this date. Format: YYYY-MM-DD (e.g. '2025-02-09')."
                    },
                    "end_date": {
                        "type": "string",
                        "default": null,
                        "description": "Return results published or updated before this date. Format: YYYY-MM-DD (e.g. '2025-12-29')."
                    },
                    "max_results": {
                        "type": "integer",
                        "default": 5,
                        "minimum": 0,
                        "maximum": 20,
                        "description": "The maximum number of search results to return. Default is 5."
                    },
                    "include_images": {
                        "type": "boolean",
                        "default": false,
                        "description": "Include a list of query-related images in the response, plus per-result images. Default is false."
                    },
                    "include_image_descriptions": {
                        "type": "boolean",
                        "default": false,
                        "description": "When include_images is true, also add a descriptive text for each image. Default is false."
                    },
                    "include_answer": {
                        "type": "string",
                        "default": "false",
                        "description": "Include an LLM-generated answer to the query. 'basic' or true returns a quick answer. 'advanced' returns a more detailed answer. Default is false.",
                        "enum": [
                            "false",
                            "basic",
                            "advanced"
                        ]
                    },
                    "include_raw_content": {
                        "type": "string",
                        "default": "false",
                        "description": "Include the cleaned and parsed HTML content of each search result. 'markdown' or true returns content in markdown format. 'text' returns plain text. Default is false.",
                        "enum": [
                            "false",
                            "markdown",
                            "text"
                        ]
                    },
                    "include_favicon": {
                        "type": "boolean",
                        "default": false,
                        "description": "Whether to include the favicon URL for each result. Default is false."
                    },
                    "include_domains": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "A list of domains to specifically include in the search results. Maximum 300 domains. Default is []."
                    },
                    "exclude_domains": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "A list of domains to specifically exclude from the search results. Maximum 150 domains. Default is []."
                    },
                    "country": {
                        "type": "string",
                        "default": null,
                        "description": "Boost search results from a specific country. Prioritizes content from the selected country. Only available when topic is 'general'.",
                        "enum": [
                            "afghanistan",
                            "albania",
                            "algeria",
                            "andorra",
