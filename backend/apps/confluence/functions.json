  {
    "name": "CONFLUENCE__CREATE_PAGE",
    "description": "Create a new Confluence page using storage format (HTML).",
    "tags": [
      "confluence",
      "write"
    ],
    "visibility": "public",
    "active": true,
    "protocol": "rest",
    "protocol_data": {
      "method": "POST",
      "path": "/ex/confluence/{cloudid}/wiki/api/v2/pages",
      "server_url": "https://api.atlassian.com"
    },
    "security_schemes": [
      "oauth2"
    ],
    "parameters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cloudid": {
              "type": "string"
            }
          },
          "required": [],
          "visible": [
            "cloudid"
          ]
        },
        "body": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "spaceId": {
              "type": "string",
              "description": "ID of the space where the page will be created"
            },
            "status": {
              "type": "string",
              "default": "current",
              "description": "Page status"
            },
            "title": {
              "type": "string",
              "description": "Title of the page"
            },
            "body": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "representation": {
                  "type": "string",
                  "default": "storage",
                  "description": "Content format (must be 'storage')"
                },
                "value": {
                  "type": "string",
                  "description": "HTML content of the page"
                }
              },
              "required": [
                "representation",
                "value"
              ],
              "visible": [
                "representation",
                "value"
              ]
            }
          },
          "required": [
            "spaceId",
            "title",
            "body"
          ],
          "visible": [
            "spaceId",
            "status",
            "title",
            "body"
          ]
        }
      },
      "required": [
        "body"
      ],
      "visible": [
        "path",
        "body"
      ]
    }
