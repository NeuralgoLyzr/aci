  {
    "name": "CONFLUENCE__UPDATE_PAGE",
    "description": "Update an existing Confluence page. Requires current version + 1.",
    "tags": [
      "confluence",
      "write"
    ],
    "visibility": "public",
    "active": true,
    "protocol": "rest",
    "protocol_data": {
      "method": "PUT",
      "path": "/ex/confluence/{cloudid}/wiki/api/v2/pages/{pageId}",
      "server_url": "https://api.atlassian.com"
    },
    "security_schemes": [
      "oauth2"
    ],
    "parameters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cloudid": {
              "type": "string"
            },
            "pageId": {
              "type": "string"
            }
          },
          "required": [
            "pageId"
          ],
          "visible": [
            "cloudid",
            "pageId"
          ]
        },
        "body": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "id": {
              "type": "string",
              "description": "Page ID (must match pageId in path)"
            },
            "status": {
              "type": "string",
              "default": "current",
              "description": "Page status"
            },
            "title": {
              "type": "string",
              "description": "Updated title of the page"
            },
            "version": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "number": {
                  "type": "integer",
                  "description": "Must be current version + 1"
                }
              },
              "required": [
                "number"
              ],
              "visible": [
                "number"
              ]
            },
            "body": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "representation": {
                  "type": "string",
                  "default": "storage",
                  "description": "Content format (must be 'storage')"
                },
                "value": {
                  "type": "string",
                  "description": "Updated HTML content"
                }
              },
              "required": [
                "representation",
                "value"
              ],
              "visible": [
                "representation",
                "value"
              ]
            }
          },
          "required": [
            "id",
            "version",
            "body"
          ],
          "visible": [
            "id",
            "status",
            "title",
            "version",
            "body"
          ]
        }
      },
      "required": [
        "path",
        "body"
      ],
      "visible": [
        "path",
        "body"
      ]
