{
    "name": "SNOWFLAKE",
    "display_name": "Snowflake",
    "logo": "https://logo.clearbit.com/snowflake.com",
    "provider": "Snowflake Inc.",
    "version": "1.0.0",
    "description": "Snowflake SQL API is a REST API for executing SQL statements against Snowflake databases, retrieving query results, and managing statement execution. This integration is designed for metadata exploration and query execution workflows such as listing databases, schemas, tables, describing tables, and exploring columns.",
    "security_schemes": {
      "oauth2": {
        "location": "header",
        "name": "Authorization",
        "prefix": "Bearer",
        "client_id": "{{ AIPOLABS_SNOWFLAKE_CLIENT_ID }}",
        "client_secret": "{{ AIPOLABS_SNOWFLAKE_CLIENT_SECRET }}",
        "scope": "refresh_token session:role:PUBLIC",
        "authorize_url": "https://{{SNOWFLAKE_ACCOUNT_URL}}/oauth/authorize",
        "access_token_url": "https://{{SNOWFLAKE_ACCOUNT_URL}}/oauth/token-request",
        "refresh_token_url": "https://{{SNOWFLAKE_ACCOUNT_URL}}/oauth/token-request"
      }
    },
    "default_security_credentials_by_scheme": {},
    "categories": [
      "Database",
      "Data",
      "Analytics"
    ],
    "visibility": "public",
    "active": true
}