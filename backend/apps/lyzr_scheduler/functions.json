[
    {
      "name": "LYZR_SCHEDULER__CREATE_SCHEDULE",
      "description": "Create a new agent schedule using cron expression.",
      "tags": ["scheduler", "create"],
      "visibility": "public",
      "active": true,
      "protocol": "rest",
      "protocol_data": {
        "method": "POST",
        "path": "/schedules/",
        "server_url": "https://scheduler.studio.lyzr.ai"
      },
      "parameters": {
        "type": "object",
        "visible": ["body"],
        "properties": {
          "body": {
            "type": "object",
            "visible": ["agent_id","cron_expression","message","timezone","user_id","max_retries","retry_delay"],
            "properties": {
              "agent_id": { "type": "string" },
              "cron_expression": { "type": "string" },
              "message": { "type": "string" },
              "timezone": { "type": "string", "default": "UTC" },
              "user_id": { "type": "string" },
              "max_retries": { "type": "integer", "default": 0 },
              "retry_delay": { "type": "integer", "default": 60 }
            },
            "required": ["agent_id","cron_expression","message","timezone","user_id"],
            "additionalProperties": false
          },
          "header": {
            "type": "object",
            "visible": [],
            "properties": {
              "Content-Type": { "type": "string", "default": "application/json" },
              "accept": { "type": "string", "default": "application/json" },
              "x-api-key": { "type": "string", "default": "{{api_key}}" }
            },
            "required": ["x-api-key"],
            "additionalProperties": false
          }
        },
        "required": ["body","header"],
        "additionalProperties": false
      }
    },
